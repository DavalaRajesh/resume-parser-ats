\"campaign_key\":\"job_caricature\"},\"1867099689756913\":{\"language_key\":\"es\",\"campaign_key\":\"photo_to_headshot\"},\"1868705151718561\":{\"campaign_key\":\"national_team_match_analysis\",\"language_key\":\"es\"},\"798449063754\":{\"language_key\":\"hi\",\"campaign_key\":\"cricket_catchup\"},\"798449148147\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"cricket_catchup\"},\"1867096724761377\":{\"language_key\":\"es\",\"campaign_key\":\"background_cleanup\"},\"798559023059\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"808801371015\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi\"},\"798502711888\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"en\"},\"799705239738\":{\"language_key\":\"en\",\"campaign_key\":\"closet_room_refresh\"},\"778169782691\":{\"language_key\":\"hi\",\"campaign_key\":\"spicy_pani_puri\"},\"1867169655795857\":{\"language_key\":\"ja\",\"campaign_key\":\"photo_to_headshot\"},\"808801371006\":{\"campaign_key\":\"photo_to_headshot\",\"language_key\":\"hi\"},\"1868259085865169\":{\"language_key\":\"pt\",\"campaign_key\":\"football_bobblehead\"},\"1867169622955153\":{\"campaign_key\":\"approachable_self_introduction\",\"language_key\":\"ja\"},\"808801662897\":{\"language_key\":\"hi\",\"campaign_key\":\"sketch_to_brand\"},\"120245713730190182\":{\"campaign_key\":\"photo_annotation\",\"language_key\":\"en\"},\"798449148135\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"hi_latn\"},\"782461526870\":{\"language_key\":\"en\",\"campaign_key\":\"stylist_workwear\"},\"799741745677\":{\"language_key\":\"en\",\"campaign_key\":\"closet_room_refresh\"},\"120241043845840182\":{\"language_key\":\"en\",\"campaign_key\":\"outfit_transfer\"},\"798559023047\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"en\"},\"798559023035\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"808801747587\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi\"},\"801737430134\":{\"language_key\":\"id\",\"campaign_key\":\"bracelet_design\"},\"120241043845760182\":{\"language_key\":\"en\",\"campaign_key\":\"mini_me_palm\"},\"1867096733187154\":{\"language_key\":\"es\",\"campaign_key\":\"background_cleanup\"},\"808801747569\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi\"},\"807296684775\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"id\"},\"812175322962\":{\"language_key\":\"ko\",\"campaign_key\":\"football_bobblehead\"},\"120247183552630182\":{\"language_key\":\"en\",\"campaign_key\":\"football_bobblehead\"},\"120245715524760182\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"hairstyle_analysis\"},\"807141203998\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"ja\"},\"799747618960\":{\"language_key\":\"id\",\"campaign_key\":\"vanity_refresh\"},\"120245715524780182\":{\"language_key\":\"hi\",\"campaign_key\":\"personal_color_analysis\"},\"808807097886\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"custom_event_sticker\"}},\"default_bootstrap_model_id\":\"gpt-5-5-instant\",\"language_instructions\":{\"en\":\"Response language for the first visible response: natural English. Use English for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"es\":\"Response language for the first visible response: natural Spanish. Use Spanish for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"hi_latn\":\"Response language for the first visible response: natural Roman Hindi using Latin script only. Translate any English campaign wording before writing. Use Roman Hindi—not English—for every visible element, including the opening, lead-in, and all three clickable suggestions. Common borrowed words are fine, but never write a complete lead-in or suggestion in English. If the user later writes in another language or script, switch naturally.\",\"ja\":\"Response language for the first visible response: natural Japanese. Use Japanese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"id\":\"Response language for the first visible response: natural Indonesian. Use Indonesian for all visible text, including the lead-in and clickable suggestions. Use standard Indonesian punctuation: keep the two opening sentences in one paragraph and end each with a period; an optional emoji may follow the first period. If the user later writes in another language, switch naturally.\",\"ko\":\"Response language for the first visible response: natural Korean. Use Korean for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"pt\":\"Response language for the first visible response: natural Brazilian Portuguese. Use Brazilian Portuguese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"hi\":\"Response language for the first visible response: natural Hindi in Devanagari. Translate any English campaign wording before writing. Use Devanagari Hindi for every visible element—the opening, lead-in, and all three clickable suggestions—and do not copy full English phrases into the response. If the user later writes in another language or script, switch naturally.\"}},\"is_device_based\":true,\"passed\":false},\"1623104352\":{\"name\":\"1623104352\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"217573384\":{\"name\":\"217573384\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"3586972587\":{\"name\":\"3586972587\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"prompt\":\"The user provided feedback on a previous completion. Use it to generate a new completion. The output should be a standalone response that reflects the feedback without acknowledging it. Do not mention, suggest, or imply that this is a revision, improvement, or result of feedback. Respond in the same language as the original completion, even if the feedback is in another language. Only switch if the feedback explicitly asks you to translate the completion. Here is the feedback:\\n\"},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"user_prompt_key\":\"good_option\"},\"is_device_based\":false,\"passed\":false},\"1355628363\":{\"name\":\"1355628363\",\"rule_id\":\"6EkzgQkSDT4MxFNtb5sHlF:100.00:5-6EkzgOFQbAViegfxzXx42D\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"prompts\":[{\"title\":\"Make a mango tasting mat\",\"body\":\"Create a bright text-light mango tasting mat with simple sections for aroma, sweetness, texture and favourite, leaving labels blank.\"},{\"title\":\"Create a music Reel backdrop\",\"body\":\"Create a text-light vertical backdrop for a music Reel. Use lively abstract shapes, no platform logos, and leave empty space for my caption.\"},{\"body\":\"Create a simple train ticket status flowchart with icons for CNF, RAC, WL and Tatkal. Keep labels short and editable.\",\"title\":\"Map train booking choices\"},{\"title\":\"Build a reading routine\",\"body\":\"Help me build a 20-minute reading routine. Ask me one question about when I can read, then suggest a first-week plan.\"},{\"title\":\"Learn to plan a short trip\",\"body\":\"Teach me how to plan a short trip from scratch. Ask one question about destination and dates, then build a simple itinerary outline.\"},{\"body\":\"Give me a fun Wimbledon 2026 primer: what makes grass-court tennis different, who to notice, and how to sound less lost.\",\"title\":\"Get into Wimbledon gently\"},{\"title\":\"Pick a Wimbledon match\",\"body\":\"Check the current Wimbledon schedule and suggest one match to follow from India, with the likely match time and one story to watch.\"},{\"title\":\"Polish a WhatsApp message\",\"body\":\"I need to send a tricky WhatsApp message. Ask me to paste it and say who it is for, then make it polite and natural.\"},{\"title\":\"Turn revision into a game\",\"body\":\"Make my unit-test revision feel like a game. Ask my subject first, then give a 20-minute plan with quick rounds.\"},{\"title\":\"Plan a rainproof commute\",\"body\":\"Make a rainy-day commute game plan. Ask my city and route first, then suggest backup transport, timing buffers and what to pack.\"},{\"title\":\"Make a cricket catch-up card\",\"body\":\"Give me a fun, no-jargon catch-up on the Women’s T20 World Cup, with India’s path, key players to notice, and one thing to watch today.\"},{\"body\":\"Build a light India vs England watch plan for July: match reminders, snack breaks, and a simple way to follow if I miss overs.\",\"title\":\"Plan a late-night cricket watch\"},{\"body\":\"Make a monthly kirana restock list. Ask my household size first, then organise staples, cleaning items and quick top-ups.\",\"title\":\"Build a kirana restock list\"},{\"title\":\"Read monsoon updates better\",\"body\":\"Explain today’s India monsoon update in plain English, including what normal, deficit and warning colours mean.\"},{\"title\":\"Build a monsoon travel buffer\",\"body\":\"Help me plan a monsoon journey with buffers for delays. Ask my city pair and travel mode, then make a practical backup plan.\"},{\"title\":\"Host a spoiler-free film chat\",\"body\":\"Make a spoiler-free debate guide for a current Indian film my friends have seen. Ask the film name, then give talking points.\"},{\"body\":\"Check the Wimbledon 2026 schedule and make me a simple IST viewing plan for the first week. Ask which players I care about.\",\"title\":\"Plan your Wimbledon viewing\"},{\"body\":\"Create a simple study quest map with 7 checkpoints, icons and blank labels. Ask me the subject first, then give label text separately.\",\"title\":\"Make a study quest map\"},{\"title\":\"Make a pantry check poster\",\"body\":\"Create a text-light pantry label-check poster with icons for MRP, expiry, ingredients, veg or non-veg symbol and storage.\"},{\"body\":\"Create a simple text-light rainy entryway layout for an Indian flat: shoe zone, umbrella spot, drying mat and hooks. No brand names.\",\"title\":\"Draw a rainy entryway\"},{\"body\":\"Help me prepare a DigiLocker-ready document set for admissions or a government service. Ask which task first.\",\"title\":\"Get documents ready online\"},{\"title\":\"Fix monsoon laundry\",\"body\":\"Make a monsoon laundry rota for a small home where clothes dry indoors. Include smell prevention, rainy-day backup and what to wash first.\"},{\"title\":\"Prepare Passport Seva papers\",\"body\":\"Help me prepare for a Passport Seva appointment. Check official document guidance and ask one question about my application type.\"},{\"title\":\"Set up DigiLocker basics\",\"body\":\"Explain DigiLocker in everyday terms and help me plan which documents to fetch, upload, or carry as originals.\"},{\"title\":\"Learn ride phrases\",\"body\":\"Teach me 8 polite phrases for an auto or cab ride. Ask my city or language first, then give pronunciation help.\"},{\"body\":\"Practise a 5-minute small-talk scene with me. Ask the setting first, then play the other person and keep it light.\",\"title\":\"Practise small talk lightly\"},{\"body\":\"Teach me a difficult topic using everyday examples. Ask me the topic first, then build a 10-minute lesson.\",\"title\":\"Learn a topic with examples\"},{\"title\":\"Pack a better tiffin\",\"body\":\"Plan 3 spill-proof tiffin ideas. Ask what I eat and whether I can reheat first, then keep it practical.\"},{\"body\":\"Make a first hostel packing list for India’s monsoon months. Ask my city and hostel rules first, then group must-haves and nice-to-haves.\",\"title\":\"Pack for hostel in the rains\"},{\"body\":\"Teach me how UPI AutoPay mandates work and give me a safe way to review subscriptions without sharing account details.\",\"title\":\"Review UPI AutoPay safely\"},{\"body\":\"Practise a short meeting update with me. Give me a simple structure, then ask one question and correct my answer gently.\",\"title\":\"Practise a meeting update\"},{\"body\":\"Create a text-light packing map for a monsoon hostel or PG room: bedding, documents, footwear, laundry and desk. Use simple icons.\",\"title\":\"Draw a hostel packing map\"},{\"body\":\"Help me make a practical monsoon plan for today: commute, footwear, laundry and bag essentials. Ask for my city first.\",\"title\":\"Rain-proof my day\"},{\"body\":\"Explain the young players people are discussing in India’s Ireland and England T20Is. Keep it beginner-friendly and avoid hype.\",\"title\":\"Understand the new India names\"},{\"title\":\"Share a UPI split politely\",\"body\":\"Write a clear, polite message to request a UPI split for a group expense. Keep it short and include a line asking people to verify payee name.\"},{\"title\":\"Plan a World Cup night\",\"body\":\"Make me a simple FIFA World Cup watch plan for India time. Ask which teams I follow, then suggest matches, snacks and a sleep-friendly routine.\"},{\"body\":\"Create a simple chore wheel with household task icons and blank name spaces. Ask how many people should fit on it first.\",\"title\":\"Create a chore wheel\"},{\"title\":\"Pack for monsoon commutes\",\"body\":\"Build a monsoon commute kit for my city and travel mode. Ask one question if needed, then group items as must-carry and optional.\"},{\"title\":\"Build a rainy commute playlist\",\"body\":\"Use current India music charts to build a 7-song playlist theme for a rainy commute. Avoid explicit lyrics unless I ask.\"},{\"body\":\"Create a text-light match-night scoreboard image for the Women’s T20 World Cup. Keep spaces blank for teams, runs, snacks, and MVP.\",\"title\":\"Create a match-night scoreboard\"},{\"title\":\"Build a smarter grocery run\",\"body\":\"Make a grocery list that prevents random extras. Ask what I’m cooking this week, then group items by store section.\"},{\"body\":\"I’ll paste only my ticket status, not my full PNR. Explain CNF, RAC or WL and tell me the next sensible check.\",\"title\":\"Decode my train status\"},{\"body\":\"Help me turn fridge leftovers into an Indian-style meal. I can upload a photo or list what I have.\",\"title\":\"Cook from fridge leftovers\"},{\"title\":\"Plan a short trip in India\",\"body\":\"Help plan a 2–3 day trip in India. First ask my starting city and rough budget, then suggest practical options.\"},{\"body\":\"Pick a song currently high on YouTube India and explain its hook, structure and replay value without quoting lyrics.\",\"title\":\"Break down a charting song\"},{\"body\":\"Teach me pressure cooker basics for dal, rice and chana, including whistles, soaking and safety checks.\",\"title\":\"Learn cooker timing basics\"},{\"title\":\"Storyboard a song hook\",\"body\":\"Create a 6-frame, text-light storyboard template for explaining why a current YouTube India song hook works, with no lyrics or artist likenesses.\"},{\"body\":\"Give me a 30-minute game plan to sort household papers into keep, act and file piles. Ask what kind of papers I have first.\",\"title\":\"Sort papers without panic\"},{\"title\":\"Pick a Van Mahotsav sapling\",\"body\":\"Help me pick one low-maintenance native sapling for Van Mahotsav. Ask my city and planting space, then give care steps.\"},{\"title\":\"Learn the World Cup knockout\",\"body\":\"Explain the FIFA World Cup knockout format for an India viewer, including how extra time and penalties work.\"},{\"body\":\"Create a text-light FIFA World Cup match-night tracker with blank team slots, score spaces, and room for IST timings.\",\"title\":\"Make a match-night tracker\"},{\"title\":\"Decode a talked-about squad pick\",\"body\":\"Give me a quick profile of a current India squad pick being searched a lot. Cover role, recent context and what to watch for.\"},{\"title\":\"Play mock interview ping-pong\",\"body\":\"Run a mock interview like ping-pong. Ask my role, then give one question at a time with a short coaching note after each answer.\"},{\"title\":\"Plan a tiffin rotation\",\"body\":\"Build a 5-day school or office tiffin rotation using Indian staples. Ask one question about dietary limits before suggesting.\"},{\"title\":\"See field positions clearly\",\"body\":\"Create a simple T20 fielding map for a new cricket fan using dots and zones, with any position names listed outside the image.\"},{\"title\":\"Understand Form 16 and AIS\",\"body\":\"Explain Form 16, AIS, 26AS and ITR in simple terms for AY 2026-27. Ask one question only if you need my income type.\"},{\"title\":\"Sort tiny UPI payments\",\"body\":\"Help me make a tiny-payment routine for chai, autos and kirana. Check current UPI Lite rules and remind me not to share PINs.\"},{\"body\":\"Explain gazetted, restricted and state holidays in India using the 2026 calendar. Give a simple rule for checking office or school closures.\",\"title\":\"Decode holiday types\"},{\"title\":\"Make chores less boring\",\"body\":\"Turn weekly chores into a fair, playful rota. Ask how many people are sharing, then suggest roles, swaps and a 10-minute reset.\"},{\"body\":\"Create a cosy, text-light image of an Indian monsoon snack board with chai, rain cues and blank label spaces.\",\"title\":\"Create a rainy-day snack board\"},{\"title\":\"Choose an OTT trailer night\",\"body\":\"Find three current India OTT trailers worth sampling tonight, then make a playful 30-minute no-spoiler watch plan.\"},{\"body\":\"Make a tiny Wimbledon bracket game I can use with friends, simple scoring, no expert knowledge needed.\",\"title\":\"Make a mini tennis bracket\"},{\"body\":\"Help me turn leftovers into dinner. Ask me for a fridge photo or ingredient list, then suggest 3 playful options with simple steps.\",\"title\":\"Remix leftovers into dinner\"},{\"title\":\"Make a tiffin idea wheel\",\"body\":\"Create a simple tiffin idea wheel with icons for grain, protein, veg, fruit and snack. Use blank labels, no brand names.\"},{\"title\":\"Discuss Kargil respectfully\",\"body\":\"Help me discuss Kargil Vijay Diwas in a balanced way for a study group. Give 5 questions that focus on history, courage and evidence.\"},{\"body\":\"Create a text-light Wimbledon bingo card image for a home watch. Use simple icons and blank squares, no player likenesses or logos.\",\"title\":\"Create a tennis bingo card\"},{\"body\":\"Create a simple layout sketch to make my desk or room easier to use. Ask for a photo or short description first.\",\"title\":\"Sketch a better room layout\"},{\"body\":\"Suggest a playful mango tasting at home for National Mango Day. Include ways to compare flavour, texture, aroma and use.\",\"title\":\"Host a mango tasting\"},{\"title\":\"Make a tennis score card\",\"body\":\"Create a clean, text-light tennis scorecard image for Wimbledon watching. Leave blanks for player names and sets. No logos.\"},{\"title\":\"Make a rainy commute card\",\"body\":\"Create a simple rainy-day commute safety card for India, using icons only and no location-specific claims.\"},{\"body\":\"Create a simple 6-panel image storyboard for a 20-second everyday Reel. Keep it text-light and use blank caption boxes.\",\"title\":\"Create a Reel storyboard\"},{\"title\":\"Reset my desk like a game\",\"body\":\"Help me reset my desk in 15 minutes. Ask me for a photo or short description, then turn it into 3 quick rounds.\"},{\"body\":\"Help me write a polite message to split a UPI payment. Ask what was paid and the amount, then make it clear without sounding awkward.\",\"title\":\"Settle a UPI split politely\"},{\"body\":\"Give me a friendly 5-minute guide to Puri Rath Yatra, including key words I’ll hear and respectful visitor basics.\",\"title\":\"Understand Rath Yatra quickly\"},{\"title\":\"Plan a late-night World Cup watch\",\"body\":\"Make a simple IST watch plan for the next FIFA World Cup 2026 matches I care about. Ask which teams I follow, then keep it realistic for workdays.\"},{\"title\":\"Design a drying corner\",\"body\":\"Create a text-light visual layout for a monsoon drying corner at home. Ask one question about space if needed.\"},{\"title\":\"Fix my match stream setup\",\"body\":\"Help me choose a reliable live-sport setup for home: TV, app or backup data. Ask what I’m watching and what devices I have.\"},{\"title\":\"Create a Rath Yatra story map\",\"body\":\"Create a simple text-light illustration of Puri Rath Yatra’s temple-to-Gundicha journey, with blank labels I can fill in.\"},{\"title\":\"Practise interview answers\",\"body\":\"Practise an interview for my role. Ask one question at a time, wait for my answer, then give brief feedback. First ask my role.\"},{\"title\":\"Write a service message\",\"body\":\"Help me write a short message to a driver, shop or technician in English and one Indian language I choose. Ask the language first.\"},{\"body\":\"Help me choose from current Hindi and pan-India theatrical releases. Ask my city and mood, then make a simple cinema plan.\",\"title\":\"Pick a cinema plan\"},{\"title\":\"Learn BGMI lag terms\",\"body\":\"Explain BGMI terms like ping, desync, FPS and server lag with simple examples a casual player would get.\"},{\"title\":\"Make a World Cup match tracker\",\"body\":\"Create a text-light World Cup match tracker image I can print. Use blank slots for teams, dates and predictions, with a clean football-night feel.\"},{\"body\":\"Show me how moon-sighting based holidays can shift on calendars. Use Muharram 2026 as the example and give a simple planning rule.\",\"title\":\"Check moon-sighting dates\"},{\"body\":\"Make a spoiler-light guide to India Women at the ICC Women’s T20 World Cup 2026. Include upcoming matches, storylines and terms to know.\",\"title\":\"Follow India Women with context\"},{\"title\":\"Create a match-night score card\",\"body\":\"Create a text-light printable score card for a FIFA World Cup watch night, with blank spaces for teams, predictions, and snacks.\"},{\"title\":\"Plan a Rath Yatra day\",\"body\":\"Help me plan a safe Rath Yatra day in Puri. Ask my travel date and starting point, then make a realistic route and packing plan.\"},{\"title\":\"Make an interview answer card\",\"body\":\"Create a simple visual card for structuring interview answers using four blank sections and small icons. Keep text minimal.\"},{\"title\":\"Plan a rain-safe commute\",\"body\":\"Help me plan a monsoon commute. Ask my city and usual route, then suggest what to check, carry and avoid today.\"},{\"body\":\"Plan a week of simple meals. Ask one question about what I eat or have at home, then give meals and a shopping list for an Indian kitchen.\",\"title\":\"Plan a week of simple meals\"},{\"title\":\"Make a weekly planner page\",\"body\":\"Create a clean weekly planner image with blank day blocks, priority space and simple symbols. Keep it mostly text-free.\"},{\"title\":\"Make a tiffin menu card\",\"body\":\"Create a text-light weekly tiffin menu card with simple food icons and blank spaces I can fill in.\"},{\"title\":\"Find a charting song angle\",\"body\":\"Use India’s current YouTube music charts to suggest one song-based Reel or Shorts idea. Keep it lyric-safe and easy to film.\"},{\"title\":\"Plan easy lunchbox ideas\",\"body\":\"Help me plan easy lunchbox ideas using what I usually buy. Ask my main staples, then keep it low-effort.\"},{\"title\":\"Make a water-check reminder\",\"body\":\"Create a text-light reminder card for a weekly stagnant-water check. Use simple home icons, no scary imagery.\"},{\"body\":\"Use current India YouTube music trends to build a no-skip queue by mood. No lyrics, just why each pick fits.\",\"title\":\"Build a trending music queue\"},{\"title\":\"Draft a leave request\",\"body\":\"Help me write a short leave request to my manager. Ask me for the dates and reason before drafting.\"},{\"body\":\"Create a clean global football knockout explainer image with generic team icons, no logos, and minimal text. Add India-time notes outside it.\",\"title\":\"Make a football bracket map\"},{\"body\":\"Make a monsoon move-in checklist for a hostel or PG. Ask me the city and room type first, then cover packing, documents and laundry.\",\"title\":\"Pack for hostel in the rains\"},{\"title\":\"Write a tactful work message\",\"body\":\"Turn my rough point into a polite but clear work message. Ask what happened, then draft it in 3 tones.\"},{\"body\":\"Create a text-light packing mood board for a weekend trip. Ask my destination and travel style first.\",\"title\":\"Make a trip packing board\"},{\"body\":\"Give me a 20-minute inbox clean-up game with rules for reply, archive and park. Ask whether it is work or personal first.\",\"title\":\"Tame my inbox in 20 minutes\"},{\"body\":\"Draft a polite apartment WhatsApp notice about a water or power issue. Ask for the timing and action needed, then keep it short.\",\"title\":\"Write a clear RWA message\"},{\"title\":\"Make a hook-step plan\",\"body\":\"Make a simple, camera-friendly hook-step idea for a trending India music video. Keep it original and easy to do at home.\"},{\"title\":\"Decode train ticket status\",\"body\":\"Explain CNF, RAC, WL, PQWL and Tatkal in plain English, then help me decide what to check before booking a train ticket.\"},{\"title\":\"Create Wimbledon bingo cards\",\"body\":\"Create a text-light Wimbledon watch bingo card image with tennis symbols, blank squares, and no official logos.\"},{\"body\":\"Create a Wimbledon watch bingo game for friends, with simple squares for rallies, crowd moments, and snack breaks.\",\"title\":\"Make Wimbledon watch bingo\"},{\"body\":\"Explain Kargil Vijay Diwas through a concise 1999 timeline, key geography and why 26 July is remembered in India.\",\"title\":\"Trace Kargil’s timeline\"},{\"title\":\"Build your World Cup watchlist\",\"body\":\"Check the latest FIFA World Cup fixtures and make me an IST watchlist for the next three nights. Ask which teams I follow.\"},{\"title\":\"Turn a trend into a clean idea\",\"body\":\"Help me adapt a tr