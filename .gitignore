</span><span class="ͼv">&amp;</span><span> </span><span class="ͼz">"C:\Program Files\Git\cmd\git.exe"</span><span> </span><span class="ͼ10">rm</span><span> </span><span class="ͼv">-</span><span class="ͼ10">r</span><span> </span><span class="ͼv">--</span><span class="ͼ11">cached</span><span> </span><span class="ͼ11">uploads</span><span>
